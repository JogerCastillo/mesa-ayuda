# Server port
PORT=4200

# REQUIRED: JWT secret. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Bcrypt rounds (8-14, default 10)
BCRYPT_ROUNDS=10

# REQUIRED in production: Comma-separated list of allowed CORS origins.
# Example: CORS_ORIGIN=https://midominio.com,https://admin.midominio.com
CORS_ORIGIN=

# Bootstrap admin password (required for first run)
ADMIN_PASSWORD=
AGENTE1_PASSWORD=
AGENTE2_PASSWORD=

# Set to "production" for deployment (enables static serving, strict CORS, secure cookies)
# NODE_ENV=production
